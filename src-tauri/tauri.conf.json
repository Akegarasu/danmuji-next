{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "danmuji-next",
  "version": "2.0.0",
  "identifier": "com.anzu.danmuji-next",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AKI 弹幕姬",
        "width": 400,
        "height": 600,
        "minWidth": 240,
        "minHeight": 200,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDgzQ0E5RTAzQTg5ODQ5MDMKUldRRFNaaW9BNTdLZ3c0c1RwR1ZiQnFTMVdWSnF6dFZFcCtHWGNGdTZtcFlRdFpCcmtKUk9UTXgK",
      "endpoints": [
        "https://akiba-1301838591.cos.ap-shanghai.myqcloud.com/update.json"
      ]
    }
  }
}